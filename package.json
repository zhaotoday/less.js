{
  "name": "less.js",
  "version": "4.0.0",
  "description": "A write less, do more MVC framework based on Koa.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sync-models": {
      "types": "./dist/sync-models.d.ts",
      "import": "./dist/sync-models.js"
    }
  },
  "bin": {
    "less-sync-models": "./dist/sync-models.js"
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@latest",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhaotoday/less.js.git"
  },
  "keywords": [
    "koa",
    "mvc"
  ],
  "author": "zhaojintian",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/zhaotoday/less.js/issues"
  },
  "homepage": "https://github.com/zhaotoday/less.js#readme",
  "devDependencies": {},
  "dependencies": {}
}
